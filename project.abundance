                    {
                      "atomType": "Code",
                      "x": 0.46880907372400754,
                      "y": 0.6,
                      "uniqueID": "id-6775",
                      "ioValues": [
                        {
                          "name": "Shape",
                          "ioValue": "__GEOMETRY_INPUT__"
                        },
                        {
                          "name": "Number",
                          "ioValue": 6.833333333333333
